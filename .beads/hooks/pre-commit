#!/bin/bash
# Pre-commit security scan — pattern-based only (no vault file)
# Scans staged files for pattern-based secrets (GitHub tokens, API keys, etc.)

python3 << 'PYEOF'
import sys
import re
import subprocess
import os

WORKSPACE = "/home/clawbot/.openclaw/workspace"

# Pattern-based secret detection
PATTERNS = [
    (re.compile(r'\bghp_[a-zA-Z0-9]{20,}\b'), "GitHub token"),
    (re.compile(r'\b(gho|ghu|ghs|ghr)_[a-zA-Z0-9]{20,}\b'), "GitHub fine-grained token"),
    (re.compile(r'\bsk-[a-zA-Z0-9_-]{20,}\b'), "OpenAI/Anthropic key"),
    (re.compile(r'\bsk-ant-[a-zA-Z0-9]{20,}\b'), "Anthropic key"),
    (re.compile(r'\bsk-proj-[a-zA-Z0-9]{20,}\b'), "Anthropic project key"),
    (re.compile(r'\b(AKIA|ABIA|ASIA|AROA)[A-Z0-9]{10,}\b'), "AWS access key"),
    (re.compile(r'\bAIza[0-9A-Za-z_-]{35,}\b'), "Google API key"),
    (re.compile(r'\bxox[baprs]-[0-9a-zA-Z,-]{10,}\b'), "Slack token"),
    (re.compile(r'\b\d{8,10}:[a-zA-Z0-9_-]{35}\b'), "Telegram bot token"),
    (re.compile(r'\bnpm_[a-zA-Z0-9]{20,}\b'), "NPM token"),
    (re.compile(r'\bpplx-[a-zA-Z0-9]{20,}\b'), "Perplexity token"),
    (re.compile(r'-----BEGIN\s+(PRIVATE|RSA|EC)\s+KEY-----'), "PEM private key"),
    (re.compile(r'\bpostgres://[^\s]+\b'), "PostgreSQL connection string"),
    (re.compile(r'\bmysql://[^\s]+\b'), "MySQL connection string"),
    (re.compile(r'\bmongodb(\+srv)?://[^\s]+\b'), "MongoDB connection string"),
    (re.compile(r'\bredis://[^\s]+\b'), "Redis connection string"),
    (re.compile(r'\bamqp://[^\s]+\b'), "AMQP connection string"),
]

# Skip binary files and common non-source files
SKIP_EXTS = [".png", ".jpg", ".gif", ".pdf", ".zip", ".tar", ".gz", ".pem", ".key", 
             ".mp4", ".mov", ".avi", ".so", ".a", ".o", ".obj"]

# Skip test files — synthetic secret patterns in tests are expected
SKIP_DIRS = ["testing/", "tests/", "test/", "__pycache__/", ".pyc"]

def looks_like_secret(line):
    """Check if a line contains a secret pattern."""
    for pattern, name in PATTERNS:
        if pattern.search(line):
            return name
    return None

def should_skip(path):
    """Check if file should be skipped from scanning."""
    # Skip by extension
    if any(path.endswith(ext) for ext in SKIP_EXTS):
        return True
    # Skip by directory
    for skip_dir in SKIP_DIRS:
        if skip_dir in path:
            return True
    return False

# Get list of staged files
try:
    result = subprocess.run(
        ["git", "diff", "--cached", "--name-only", "--diff-filter=ACM"],
        capture_output=True, text=True, cwd=WORKSPACE
    )
    staged_files = [f.strip() for f in result.stdout.strip().split("\n") if f.strip()]
except Exception as e:
    print(f"Could not get staged files: {e}")
    sys.exit(1)

if not staged_files:
    print("No files staged — skipping scan")
    sys.exit(0)

secrets_found = []

for file_path in staged_files:
    if should_skip(file_path):
        continue
    
    full_path = os.path.join(WORKSPACE, file_path)
    
    if not os.path.isfile(full_path):
        continue
    
    try:
        with open(full_path, "r", errors="ignore") as f:
            for line_num, line in enumerate(f, 1):
                secret_type = looks_like_secret(line)
                if secret_type:
                    secrets_found.append(f"  {file_path}:{line_num} — {secret_type}")
                    break  # Only report once per file
    except Exception:
        continue

if secrets_found:
    print("\n=== SECURITY SCAN FAILED ===")
    print("Secret patterns detected in staged files:")
    for s in secrets_found:
        print(s)
    print("\nCommit blocked.")
    sys.exit(1)
else:
    print("Security scan passed")
    sys.exit(0)
PYEOF

# --- BEGIN BEADS INTEGRATION v1.0.2 ---
# This section is managed by beads. Do not remove these markers.
if command -v bd >/dev/null 2>&1; then
  export BD_GIT_HOOK=1
  _bd_timeout=${BEADS_HOOK_TIMEOUT:-300}
  if command -v timeout >/dev/null 2>&1; then
    timeout "$_bd_timeout" bd hooks run pre-commit "$@"
    _bd_exit=$?
    if [ $_bd_exit -eq 124 ]; then
      echo >&2 "beads: hook 'pre-commit' timed out after ${_bd_timeout}s — continuing without beads"
      _bd_exit=0
    fi
  else
    bd hooks run pre-commit "$@"
    _bd_exit=$?
  fi
  if [ $_bd_exit -eq 3 ]; then
    echo >&2 "beads: database not initialized — skipping hook 'pre-commit'"
    _bd_exit=0
  fi
  if [ $_bd_exit -ne 0 ]; then exit $_bd_exit; fi
fi
# --- END BEADS INTEGRATION v1.0.2 ---